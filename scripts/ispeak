#!/bin/bash
# ispeak — iSpeak 控制命令
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMAND_NAME="$(basename "$0")"
VERSION=""
if [[ -f "$SCRIPT_DIR/../package.json" ]]; then
  VERSION=$(grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "$SCRIPT_DIR/../package.json" | head -1 | sed 's/.*: *"\(.*\)"/\1/')
fi
VERSION="${VERSION:-1.7.0}"
SOCK="$HOME/.config/iSpeak/ispeak.sock"
PLIST="$HOME/Library/LaunchAgents/com.ispeak.plist"
LEGACY_PLIST="$HOME/Library/LaunchAgents/com.iSpeak.plist"
SOURCE="${ISPEAK_SOURCE:-}"

if [[ -z "$SOURCE" ]]; then
  case "$COMMAND_NAME" in
    ispeak-claude) SOURCE="claude" ;;
    ispeak-codex) SOURCE="codex" ;;
    ispeak-copilot) SOURCE="copilot" ;;
    ispeak-pi) SOURCE="pi" ;;
  esac
fi

cmd_status() {
  echo "== iSpeak =="
  if pgrep ispeakd > /dev/null 2>&1; then
    echo "  进程: $(pgrep ispeakd) ✓"
  else
    echo "  进程: 未运行 ✗"
  fi
  if [[ -S "$SOCK" ]]; then
    echo "  Socket: ✓"
  else
    echo "  Socket: ✗"
  fi
}

cmd_restart() {
  launchctl unload "$LEGACY_PLIST" 2>/dev/null || true
  launchctl unload "$PLIST" 2>/dev/null || true
  launchctl load "$PLIST"
  sleep 0.5
  if [[ -S "$SOCK" ]]; then
    echo "ispeak: 已重启"
  else
    echo "ispeak: 重启失败" >&2
    exit 1
  fi
}

case "${1:-}" in
  status) cmd_status ;;
  restart) cmd_restart ;;
  version|-v|--version) echo "iSpeak $VERSION" ;;
  "")
    echo "iSpeak $VERSION"
    echo ""
    echo "用法:"
    echo "  ispeak \"文本\"     播报"
    echo "  ispeak-claude \"文本\"  使用 Claude 音色播报"
    echo "  ispeak-codex \"文本\"   使用 Codex 音色播报"
    echo "  ispeak-copilot \"文本\" 使用 Copilot 音色播报"
    echo "  ispeak-pi \"文本\"      使用 Pi 音色播报"
    echo "  ispeak status      服务状态"
    echo "  ispeak restart     重启服务"
    echo "  ispeak version     版本"
    ;;
  *)
    payload="$*"
    if [[ -n "$SOURCE" && "$payload" != \{source:* ]]; then
      payload="{source:${SOURCE}}${payload}"
    fi
    if [[ "${ISPEAK_CLI_PRINT_PAYLOAD:-}" == "1" ]]; then
      printf "%s" "$payload"
      exit 0
    fi
    printf "%s" "$payload" | nc -U -w5 "$SOCK" 2>/dev/null || echo "ispeak: socket 不可用" >&2
    ;;
esac
