#!/bin/bash
# ispeak — iSpeak 控制命令
set -euo pipefail

SOCK=/tmp/ispeak.sock
PLIST="$HOME/Library/LaunchAgents/com.iSpeak.plist"
LOG=/tmp/iSpeak.log

usage() {
  cat <<'EOF'
usage:
  ispeak "文本"            直接播报
  ispeak say "文本"        播报文本
  ispeak status            查看服务/Socket状态
  ispeak test [文本]       发送测试播报
  ispeak restart           重启服务
  ispeak recover           重启并自检
  ispeak logs [N]          查看最近 N 行日志（默认 50）
  ispeak tail              实时日志
EOF
}

send_text() {
  local text="$1"
  [[ -z "$text" ]] && return 0
  printf "%s" "$text" | nc -U -w5 "$SOCK" 2>/dev/null || {
    echo "ispeak: 发送失败（socket 不可用）" >&2
    return 1
  }
}

# 根据程序名获取默认来源
get_default_source() {
  local prog="$(basename "$0")"
  case "$prog" in
    ispeak-claude) echo "claude" ;;
    ispeak-codex) echo "codex" ;;
    *) echo "" ;;
  esac
}

cmd_status() {
  echo "== iSpeak 状态 =="
  launchctl list | grep -i iSpeak | awk '{print "  进程: PID="$1" 状态="$3}'
  echo "  Socket: $SOCK"
  ls -l "$SOCK" 2>/dev/null | awk '{print "  "$1" "$9}' || echo "  ✗ socket 缺失"
  echo ""
  echo "== 音色列表 =="
  local cfg="$HOME/.config/iSpeak/config.json"
  if [[ -f "$cfg" ]]; then
    python3 - "$cfg" <<'PYEOF' 2>/dev/null
import json, sys
try:
    with open(sys.argv[1]) as f:
        cfg = json.load(f)
    voices = cfg.get("voiceList", [])
    enabled = [v for v in voices if v.get("enabled", True)]
    disabled = [v for v in voices if not v.get("enabled", True)]
    print(f"  启用中 ({len(enabled)}):")
    for v in enabled:
        print(f"    ✓ {v.get('remark', v['voice_type'])}")
    if disabled:
        print(f"  已禁用 ({len(disabled)}):")
        for v in disabled:
            print(f"    ✗ {v.get('remark', v['voice_type'])}")
except Exception as e:
    print(f"  解析失败: {e}")
PYEOF
  else
    echo "  配置文件不存在: $cfg"
  fi
}

cmd_restart() {
  launchctl unload "$PLIST" 2>/dev/null || true
  rm -f "$SOCK"
  launchctl load "$PLIST"
  echo "ispeak: restarted"
}

cmd_test() {
  local text="${1:-飞哥，ispeak 测试通过}"
  send_text "$(build_msg "$text")"
}

cmd_logs() {
  local n="${1:-50}"
  tail -n "$n" "$LOG"
}

cmd_tail() {
  tail -f "$LOG"
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

# 处理全局 --source 参数
SOURCE_FLAG=""
if [[ "$1" == "--source" ]]; then
  SOURCE_FLAG="$2"
  shift 2
fi

# 如果程序名是 ispeak-claude 或 ispeak-codex，设置默认来源
if [[ -z "$SOURCE_FLAG" ]]; then
  SOURCE_FLAG=$(get_default_source)
fi

build_msg() {
  local text="$1"
  if [[ -n "$SOURCE_FLAG" ]]; then
    echo "{source:${SOURCE_FLAG}}${text}"
  else
    echo "$text"
  fi
}

case "$1" in
  status)
    cmd_status
    ;;
  say)
    shift
    if [[ $# -eq 0 ]]; then
      if [[ -t 0 ]]; then
        usage
        exit 1
      fi
      send_text "$(build_msg "$(cat)")"
    else
      send_text "$(build_msg "$*")"
    fi
    ;;
  test)
    shift
    cmd_test "${*:-}"
    ;;
  restart)
    cmd_restart
    ;;
  recover)
    cmd_restart
    sleep 1
    cmd_status
    cmd_test
    ;;
  logs)
    shift
    cmd_logs "${1:-50}"
    ;;
  tail)
    cmd_tail
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    # 兼容：ispeak "文本"
    send_text "$(build_msg "$*")"
    ;;
esac
