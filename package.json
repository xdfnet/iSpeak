{
  "name": "@xdfnet/ispeak",
  "version": "1.7.0",
  "description": "Local macOS TTS daemon for AI coding assistants, powered by Volcengine streaming TTS.",
  "license": "MIT",
  "homepage": "https://github.com/xdfnet/iSpeak#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xdfnet/iSpeak.git"
  },
  "bugs": {
    "url": "https://github.com/xdfnet/iSpeak/issues"
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "bin": {
    "ispeak": "scripts/ispeak"
  },
  "scripts": {
    "build": "go build -ldflags=\"-s -w\" -o build/ispeakd .",
    "test": "go test ./...",
    "prepublishOnly": "make test",
    "postinstall": "node npm/postinstall.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "files": [
    "main.go",
    "clean_text.go",
    "avaudioengine_player_darwin.go",
    "stream_player_unsupported.go",
    "main_test.go",
    "Makefile",
    "CLAUDE.md",
    "AGENTS.md",
    "go.mod",
    "go.sum",
    "scripts/ispeak",
    "configs/",
    "npm/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  }
}
